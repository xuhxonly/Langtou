#!/usr/bin/env groovy
// ==========================================
// Langtou 社交内容社区 APP - Jenkins CI/CD Pipeline
// ==========================================
// 功能: PR/MR触发 -> 代码检出 -> 代码质量检查 -> Maven编译/单元测试 -> API集成测试
//       -> 覆盖率门禁 -> Docker构建 -> 推送镜像 -> 部署到开发环境(自动) -> 部署到生产环境(手动确认)
// ==========================================

pipeline {
    agent any

    environment {
        // 项目配置
        PROJECT_NAME = 'your-project-name'
        DOCKER_REGISTRY = 'docker.io'
        DOCKER_NAMESPACE = 'your-project-name'
        K8S_NAMESPACE = 'your-project-name'

        // 服务列表 (包含推荐服务)
        JAVA_SERVICES = 'gateway,user-service,content-service,interact-service,message-service'
        PYTHON_SERVICES = 'recommendation-service'
        ALL_SERVICES = 'gateway,user-service,content-service,interact-service,message-service,recommendation-service'

        // 凭证ID (需在Jenkins中预先配置)
        DOCKER_CREDENTIALS_ID = 'docker-registry-credentials'
        K8S_CREDENTIALS_ID = 'k8s-kubeconfig'
        GIT_CREDENTIALS_ID = 'git-credentials'

        // Maven配置
        MAVEN_OPTS = '-Dmaven.test.failure.ignore=true -DskipTests=false'

        // 覆盖率门禁阈值
        COVERAGE_MIN_THRESHOLD = '75'

        // 测试报告目录
        TEST_REPORT_DIR = 'src/backend/test-reports'

        // 邮件通知配置
        EMAIL_RECIPIENTS = 'your-team@example.com'
    }

    options {
        buildDiscarder(logRotator(numToKeepStr: '10'))
        timeout(time: 90, unit: 'MINUTES')
        disableConcurrentBuilds()
        // 保留测试产物
        preserveStashes(buildCount: 3)
    }

    triggers {
        // 每晚2点自动构建develop分支
        cron('H 2 * * *')
    }

    // ==========================================
    // PR/MR 自动触发机制
    // ==========================================
    // 支持 GitHub PR、GitLab MR、Gitee PR
    // 需要安装对应的多分支扫描插件:
    //   - GitHub: GitHub Branch Source Plugin + GitHub Integration Plugin
    //   - GitLab: GitLab Branch Source Plugin + GitLab Plugin
    //   - Gitee: Gitee Plugin
    //
    // 在 Jenkins Job 配置中启用:
    //   "Scan Multibranch Pipeline Triggers" -> "PR/MR 自动触发"
    //   或使用 Generic Webhook Trigger 插件
    //
    // 以下为声明式触发配置 (配合 multibranch pipeline 使用):

    stages {
        // ==========================================
        // Stage 1: 代码检出
        // ==========================================
        stage('Checkout') {
            steps {
                script {
                    echo "=================================="
                    echo "正在检出代码..."
                    echo "=================================="
                    // 判断是否为PR/MR构建
                    env.IS_PR_BUILD = env.CHANGE_ID ? 'true' : 'false'
                    if (env.IS_PR_BUILD == 'true') {
                        echo "PR/MR 构建检测: PR#${env.CHANGE_ID} (来源分支: ${env.CHANGE_BRANCH} -> 目标分支: ${env.CHANGE_TARGET})"
                    }
                }
                checkout scm
                sh '''
                    echo "Git Commit: $(git rev-parse HEAD)"
                    echo "Git Branch: $(git rev-parse --abbrev-ref HEAD)"
                    echo "Build Time: $(date '+%Y-%m-%d %H:%M:%S')"
                    echo "Is PR Build: ${IS_PR_BUILD:-false}"
                '''
            }
        }

        // ==========================================
        // Stage 2: 代码质量检查
        // ==========================================
        stage('Code Quality') {
            parallel {
                stage('Checkstyle') {
                    steps {
                        dir('src/backend') {
                            sh 'mvn checkstyle:check -f pom.xml || true'
                        }
                    }
                }
                stage('SpotBugs') {
                    steps {
                        dir('src/backend') {
                            sh 'mvn spotbugs:check -f pom.xml || true'
                        }
                    }
                }
            }
        }

        // ==========================================
        // Stage 3: Maven编译与单元测试
        // ==========================================
        stage('Build & Unit Test') {
            steps {
                script {
                    echo "=================================="
                    echo "开始 Maven 编译与单元测试..."
                    echo "=================================="
                }
                dir('src/backend') {
                    sh 'mvn clean compile ${MAVEN_OPTS}'
                    sh 'mvn test ${MAVEN_OPTS}'
                }
            }
            post {
                always {
                    // 收集单元测试报告
                    junit 'src/backend/**/target/surefire-reports/*.xml'
                    // 收集覆盖率报告
                    jacoco(
                        execPattern: 'src/backend/**/target/jacoco.exec',
                        classPattern: 'src/backend/**/target/classes',
                        sourcePattern: 'src/backend/**/src/main/java'
                    )
                    // 归档HTML测试报告
                    archiveArtifacts artifacts: 'src/backend/**/target/surefire-reports/*.xml', allowEmptyArchive: true
                    archiveArtifacts artifacts: 'src/backend/**/target/site/jacoco/**', allowEmptyArchive: true
                }
            }
        }

        // ==========================================
        // Stage 4: API集成测试 (新增)
        // ==========================================
        stage('API Integration Test') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                    branch 'feature/*'
                    expression { return env.IS_PR_BUILD == 'true' }
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "开始 API 集成测试..."
                    echo "=================================="

                    dir('langtou-devops') {
                        // 运行API集成测试脚本
                        // 脚本会启动测试环境、等待健康检查、执行REST Assured测试、生成报告
                        sh '''
                            chmod +x scripts/run-api-tests.sh
                            ./scripts/run-api-tests.sh
                        '''
                    }
                }
            }
            post {
                always {
                    // 归档API集成测试报告 (Failsafe)
                    junit 'src/backend/**/target/failsafe-reports/*.xml'
                    // 归档HTML报告
                    archiveArtifacts artifacts: 'src/backend/**/target/failsafe-reports/*.xml', allowEmptyArchive: true
                    // 发布HTML报告供Jenkins界面查看
                    publishHTML(target: [
                        allowMissing: true,
                        alwaysLinkToLastBuild: true,
                        keepAll: true,
                        reportDir: 'src/backend/target/site',
                        reportFiles: 'failsafe-report.html',
                        reportName: 'API Integration Test Report',
                        reportTitles: 'API Integration Test Results'
                    ])
                }
                failure {
                    script {
                        echo "API集成测试失败! 查看测试报告获取详细信息。"
                    }
                }
            }
        }

        // ==========================================
        // Stage 5: 覆盖率门禁检查 (新增)
        // ==========================================
        stage('Coverage Gate') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                    expression { return env.IS_PR_BUILD == 'true' }
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "检查测试覆盖率 (阈值: ${COVERAGE_MIN_THRESHOLD}%)..."
                    echo "=================================="

                    dir('langtou-devops') {
                        sh '''
                            chmod +x scripts/check-coverage.sh
                            ./scripts/check-coverage.sh "${COVERAGE_MIN_THRESHOLD}"
                        '''
                    }
                }
            }
            post {
                failure {
                    script {
                        echo "=================================="
                        echo "覆盖率未达到 ${COVERAGE_MIN_THRESHOLD}% 门禁阈值!"
                        echo "合并将被阻断，请提升测试覆盖率后重新提交。"
                        echo "=================================="
                    }
                }
            }
        }

        // ==========================================
        // Stage 6: 集成测试 (原有)
        // ==========================================
        stage('Integration Test') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                dir('src/backend') {
                    sh 'mvn verify -P integration-test ${MAVEN_OPTS} || true'
                }
            }
        }

        // ==========================================
        // Stage 7: Docker镜像构建 (并行构建所有服务)
        // ==========================================
        stage('Docker Build') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "开始构建 Docker 镜像..."
                    echo "=================================="

                    def imageTag = env.GIT_COMMIT?.take(8) ?: 'latest'
                    def branchName = env.GIT_BRANCH?.replaceAll('origin/', '') ?: 'latest'

                    env.IMAGE_TAG = imageTag
                    env.BRANCH_NAME = branchName

                    // 登录Docker仓库
                    withCredentials([usernamePassword(
                        credentialsId: "${DOCKER_CREDENTIALS_ID}",
                        usernameVariable: 'DOCKER_USER',
                        passwordVariable: 'DOCKER_PASS'
                    )]) {
                        sh "echo \${DOCKER_PASS} | docker login \${DOCKER_REGISTRY} -u \${DOCKER_USER} --password-stdin"
                    }

                    // 并行构建所有Java服务镜像
                    def javaServices = env.JAVA_SERVICES.split(',')
                    def javaBuildJobs = [:]

                    javaServices.each { service ->
                        javaBuildJobs["Build-${service}"] = {
                            dir("src/backend/${service}") {
                                sh """
                                    docker build \
                                        -t \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${IMAGE_TAG} \
                                        -t \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${BRANCH_NAME} \
                                        -f Dockerfile \
                                        --build-arg JAR_FILE=target/${service}-*.jar \
                                        .
                                """
                            }
                        }
                    }

                    // 并行构建Python推荐服务镜像
                    def pythonServices = env.PYTHON_SERVICES.split(',')
                    def pythonBuildJobs = [:]

                    pythonServices.each { service ->
                        pythonBuildJobs["Build-${service}"] = {
                            dir("src/recommendation") {
                                sh """
                                    docker build \
                                        -t \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${IMAGE_TAG} \
                                        -t \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${BRANCH_NAME} \
                                        -f Dockerfile \
                                        .
                                """
                            }
                        }
                    }

                    // 合并所有构建任务并并行执行
                    def allBuildJobs = javaBuildJobs + pythonBuildJobs
                    parallel allBuildJobs
                }
            }
        }

        // ==========================================
        // Stage 8: 推送镜像到仓库
        // ==========================================
        stage('Push Images') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "推送镜像到仓库..."
                    echo "=================================="

                    def allServices = env.ALL_SERVICES.split(',')
                    def pushJobs = [:]

                    allServices.each { service ->
                        pushJobs["Push-${service}"] = {
                            sh """
                                docker push \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${IMAGE_TAG}
                                docker push \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${BRANCH_NAME}
                            """
                        }
                    }

                    parallel pushJobs
                }
            }
        }

        // ==========================================
        // Stage 9: 安全扫描
        // ==========================================
        stage('Security Scan') {
            when {
                anyOf {
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    def allServices = env.ALL_SERVICES.split(',')
                    allServices.each { service ->
                        sh """
                            # 使用Trivy进行镜像安全扫描
                            trivy image \
                                --severity HIGH,CRITICAL \
                                --exit-code 1 \
                                --format table \
                                \${DOCKER_REGISTRY}/\${DOCKER_NAMESPACE}/${service}:\${IMAGE_TAG}
                        """
                    }
                }
            }
        }

        // ==========================================
        // Stage 10: Flyway数据库迁移
        // ==========================================
        stage('Flyway Migration') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "执行 Flyway 数据库迁移..."
                    echo "=================================="

                    withCredentials([usernamePassword(
                        credentialsId: 'mysql-credentials',
                        usernameVariable: 'DB_USER',
                        passwordVariable: 'DB_PASS'
                    )]) {
                        dir('infrastructure/database/flyway') {
                            sh """
                                docker run --rm \
                                    -v \$(pwd)/migrations:/flyway/sql \
                                    -v \$(pwd)/flyway.conf:/flyway/conf/flyway.conf \
                                    flyway/flyway:10 \
                                    -url=jdbc:mysql://\${DB_HOST:-langtou-mysql}:3306/langtou?useSSL=false\&allowPublicKeyRetrieval=true \
                                    -user=\${DB_USER} \
                                    -password=\${DB_PASS} \
                                    migrate
                            """
                        }
                    }
                }
            }
        }

        // ==========================================
        // Stage 11: 更新Elasticsearch索引
        // ==========================================
        stage('Update ES Index') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "更新 Elasticsearch 索引..."
                    echo "=================================="

                    dir('langtou-devops') {
                        sh """
                            chmod +x scripts/update-es-index.sh || true
                            ./scripts/update-es-index.sh || echo 'ES索引更新脚本未找到或执行失败，继续部署'
                        """
                    }
                }
            }
        }

        // ==========================================
        // Stage 12: 部署到开发环境 (自动)
        // ==========================================
        stage('Deploy to Dev') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'feature/*'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "自动部署到开发环境..."
                    echo "=================================="

                    env.DEPLOY_ENV = 'dev'

                    withCredentials([file(
                        credentialsId: "${K8S_CREDENTIALS_ID}",
                        variable: 'KUBECONFIG'
                    )]) {
                        dir('langtou-devops') {
                            sh """
                                chmod +x scripts/deploy-k8s.sh
                                ./scripts/deploy-k8s.sh \${DEPLOY_ENV} \${IMAGE_TAG}
                            """
                        }
                    }
                }
            }
        }

        // ==========================================
        // Stage 13: 部署到生产环境 (手动确认)
        // ==========================================
        stage('Deploy to Production') {
            when {
                anyOf {
                    branch 'main'
                    branch 'master'
                    branch 'release/*'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "准备部署到生产环境..."
                    echo "=================================="

                    // 确定部署环境
                    def deployEnv = 'staging'
                    if (env.BRANCH_NAME == 'main' || env.BRANCH_NAME == 'master') {
                        deployEnv = 'prod'
                    }

                    env.DEPLOY_ENV = deployEnv

                    // 等待手动确认
                    def userInput = input(
                        id: 'deploy-to-prod',
                        message: "确认部署到 ${deployEnv} 环境?",
                        parameters: [
                            choice(
                                name: 'DEPLOY_ACTION',
                                choices: ['Deploy', 'Abort'],
                                description: '选择操作'
                            ),
                            string(
                                name: 'DEPLOY_NOTE',
                                defaultValue: '',
                                description: '部署备注 (可选)'
                            )
                        ]
                    )

                    if (userInput['DEPLOY_ACTION'] == 'Deploy') {
                        echo "=================================="
                        echo "部署到 ${deployEnv} 环境..."
                        echo "=================================="

                        withCredentials([file(
                            credentialsId: "${K8S_CREDENTIALS_ID}",
                            variable: 'KUBECONFIG'
                        )]) {
                            dir('langtou-devops') {
                                sh """
                                    chmod +x scripts/deploy-k8s.sh
                                    ./scripts/deploy-k8s.sh \${DEPLOY_ENV} \${IMAGE_TAG}
                                """
                            }
                        }
                    } else {
                        echo "用户取消了部署"
                        currentBuild.result = 'ABORTED'
                        error('部署已取消')
                    }
                }
            }
        }

        // ==========================================
        // Stage 14: 健康检查 (带重试逻辑)
        // ==========================================
        stage('Health Check') {
            when {
                anyOf {
                    branch 'develop'
                    branch 'release/*'
                    branch 'main'
                    branch 'master'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "执行健康检查..."
                    echo "=================================="

                    // 等待服务启动
                    sleep(time: 30, unit: 'SECONDS')

                    // 检查Gateway健康端点
                    def gatewayUrl = ""
                    if (env.DEPLOY_ENV == 'dev') {
                        gatewayUrl = "http://gateway.langtou-dev.local/actuator/health"
                    } else if (env.DEPLOY_ENV == 'staging') {
                        gatewayUrl = "http://gateway.langtou-staging.local/actuator/health"
                    } else {
                        gatewayUrl = "http://gateway.langtou.local/actuator/health"
                    }

                    def healthCheckPassed = false
                    def maxRetries = 5
                    def retryDelay = 15

                    for (int i = 1; i <= maxRetries; i++) {
                        echo "健康检查尝试 ${i}/${maxRetries}..."
                        def result = sh(
                            script: """
                                curl -f -s -o /dev/null -w "%{http_code}" \
                                    --max-time 30 \
                                    ${gatewayUrl}
                            """,
                            returnStdout: true,
                            returnStatus: false
                        ).trim()

                        if (result == "200") {
                            echo "健康检查通过!"
                            healthCheckPassed = true
                            break
                        } else {
                            echo "健康检查返回状态码: ${result}，${retryDelay}秒后重试..."
                            sleep(time: retryDelay, unit: 'SECONDS')
                        }
                    }

                    if (!healthCheckPassed) {
                        echo "健康检查失败，触发回滚..."
                        currentBuild.result = 'FAILURE'
                        error("健康检查在 ${maxRetries} 次尝试后仍然失败")
                    }
                }
            }
        }

        // ==========================================
        // Stage 15: 自动回滚 (部署失败时)
        // ==========================================
        stage('Auto Rollback') {
            when {
                expression {
                    currentBuild.result == 'FAILURE' || currentBuild.result == 'UNSTABLE'
                }
            }
            steps {
                script {
                    echo "=================================="
                    echo "部署失败，执行自动回滚..."
                    echo "=================================="

                    withCredentials([file(
                        credentialsId: "${K8S_CREDENTIALS_ID}",
                        variable: 'KUBECONFIG'
                    )]) {
                        def allServices = env.ALL_SERVICES.split(',')

                        allServices.each { service ->
                            echo "回滚服务: ${service}"
                            sh """
                                kubectl rollout undo deployment/${service} -n ${K8S_NAMESPACE} || echo "${service} 回滚失败或无需回滚"
                            """
                        }

                        // 等待回滚完成
                        echo "等待回滚完成..."
                        sleep(time: 30, unit: 'SECONDS')

                        // 验证回滚后的状态
                        allServices.each { service ->
                            sh """
                                kubectl rollout status deployment/${service} -n ${K8S_NAMESPACE} --timeout=120s || echo "${service} 回滚状态检查超时"
                            """
                        }
                    }

                    echo "回滚完成!"
                }
            }
        }

        // ==========================================
        // Stage 16: 清理
        // ==========================================
        stage('Cleanup') {
            steps {
                script {
                    echo "=================================="
                    echo "清理构建产物..."
                    echo "=================================="

                    // 清理本地镜像以节省空间
                    sh '''
                        docker system prune -f || true
                        docker volume prune -f || true
                    '''
                }
            }
        }
    }

    // ==========================================
    // Post 构建处理
    // ==========================================
    post {
        always {
            script {
                echo "=================================="
                echo "构建完成: ${currentBuild.result}"
                echo "=================================="
            }
        }

        success {
            script {
                echo "构建成功!"
                echo "镜像标签: ${env.IMAGE_TAG}"
                echo "分支: ${env.BRANCH_NAME}"
            }
            // Slack通知
            slackSend(
                color: 'good',
                message: "Langtou 构建成功! :white_check_mark:\n项目: ${env.JOB_NAME}\n构建号: #${env.BUILD_NUMBER}\n分支: ${env.BRANCH_NAME}\n镜像: ${env.IMAGE_TAG}\n部署环境: ${env.DEPLOY_ENV ?: 'N/A'}\n查看详情: ${env.BUILD_URL}",
                channel: '#langtou-builds',
                tokenCredentialId: 'slack-webhook-token'
            )
            // 钉钉通知 (占位)
            dingTalk(
                robot: 'langtou-robot',
                type: 'MARKDOWN',
                title: 'Langtou 构建成功',
                text: [
                    "## Langtou 构建成功 :white_check_mark:",
                    "",
                    "- **项目**: ${env.JOB_NAME}",
                    "- **构建号**: #${env.BUILD_NUMBER}",
                    "- **分支**: ${env.BRANCH_NAME}",
                    "- **镜像标签**: ${env.IMAGE_TAG}",
                    "- **部署环境**: ${env.DEPLOY_ENV ?: 'N/A'}",
                    "- [查看详情](${env.BUILD_URL})"
                ].join('\n')
            )
        }

        failure {
            script {
                echo "构建失败,请检查日志!"
            }
            // Slack通知
            slackSend(
                color: 'danger',
                message: "Langtou 构建失败! :x:\n项目: ${env.JOB_NAME}\n构建号: #${env.BUILD_NUMBER}\n分支: ${env.BRANCH_NAME}\n查看详情: ${env.BUILD_URL}",
                channel: '#langtou-builds',
                tokenCredentialId: 'slack-webhook-token'
            )
            // 钉钉通知 (占位)
            dingTalk(
                robot: 'langtou-robot',
                type: 'MARKDOWN',
                title: 'Langtou 构建失败',
                text: [
                    "## Langtou 构建失败 :x:",
                    "",
                    "- **项目**: ${env.JOB_NAME}",
                    "- **构建号**: #${env.BUILD_NUMBER}",
                    "- **分支**: ${env.BRANCH_NAME}",
                    "- **失败阶段**: ${env.STAGE_NAME ?: 'Unknown'}",
                    "- [查看详情](${env.BUILD_URL})"
                ].join('\n')
            )
            // ==========================================
            // 测试失败邮件通知 (新增)
            // ==========================================
            emailext(
                subject: "[FAILED] Langtou CI #${env.BUILD_NUMBER} - ${env.BRANCH_NAME} 构建失败",
                body: """<!DOCTYPE html>
<html>
<head>
<style>
  body { font-family: Arial, sans-serif; font-size: 14px; color: #333; }
  .header { background-color: #d9534f; color: white; padding: 15px; }
  .content { padding: 20px; }
  .info-table { border-collapse: collapse; width: 100%; margin-top: 10px; }
  .info-table th, .info-table td { border: 1px solid #ddd; padding: 8px; text-align: left; }
  .info-table th { background-color: #f5f5f5; }
  .failure-reason { background-color: #fcf8e3; border-left: 4px solid #f0ad4e; padding: 10px; margin: 10px 0; }
  .footer { margin-top: 20px; padding-top: 10px; border-top: 1px solid #ddd; color: #999; font-size: 12px; }
  .btn { display: inline-block; padding: 10px 20px; background-color: #5cb85c; color: white; text-decoration: none; border-radius: 4px; }
</style>
</head>
<body>
  <div class="header">
    <h2>Langtou CI 构建失败通知</h2>
  </div>
  <div class="content">
    <p>构建 <strong>#${env.BUILD_NUMBER}</strong> 在分支 <strong>${env.BRANCH_NAME}</strong> 上执行失败。</p>

    <table class="info-table">
      <tr><th>项目</th><td>${env.JOB_NAME}</td></tr>
      <tr><th>构建号</th><td>#${env.BUILD_NUMBER}</td></tr>
      <tr><th>分支</th><td>${env.BRANCH_NAME}</td></tr>
      <tr><th>提交</th><td>${env.GIT_COMMIT?.take(8) ?: 'N/A'}</td></tr>
      <tr><th>失败阶段</th><td>${env.STAGE_NAME ?: 'Unknown'}</td></tr>
      <tr><th>触发者</th><td>${env.BUILD_CAUSE ?: 'N/A'}</td></tr>
      <tr><th>构建时间</th><td>${currentBuild.startTimeInMillis ? new Date(currentBuild.startTimeInMillis).format('yyyy-MM-dd HH:mm:ss') : 'N/A'}</td></tr>
    </table>

    <div class="failure-reason">
      <strong>可能原因:</strong><br/>
      - 单元测试失败 (检查 surefire-reports)<br/>
      - API集成测试失败 (检查 failsafe-reports)<br/>
      - 测试覆盖率未达到 ${COVERAGE_MIN_THRESHOLD}% 门禁阈值<br/>
      - 代码质量检查未通过<br/>
      - 编译错误
    </div>

    <p><a class="btn" href="${env.BUILD_URL}">查看构建详情</a></p>
    <p><a href="${env.BUILD_URL}console">查看完整日志</a> | <a href="${env.BUILD_URL}testReport">查看测试报告</a></p>
  </div>
  <div class="footer">
    <p>此邮件由 Langtou CI/CD Pipeline 自动发送，请勿直接回复。</p>
  </div>
</body>
</html>""",
                to: "${EMAIL_RECIPIENTS}",
                mimeType: 'text/html'
            )
        }

        unstable {
            script {
                echo "构建不稳定,可能存在测试失败!"
            }
            // Slack通知
            slackSend(
                color: 'warning',
                message: "Langtou 构建不稳定! :warning:\n项目: ${env.JOB_NAME}\n构建号: #${env.BUILD_NUMBER}\n分支: ${env.BRANCH_NAME}\n查看详情: ${env.BUILD_URL}",
                channel: '#langtou-builds',
                tokenCredentialId: 'slack-webhook-token'
            )
            // 不稳定构建也发送邮件通知
            emailext(
                subject: "[UNSTABLE] Langtou CI #${env.BUILD_NUMBER} - ${env.BRANCH_NAME} 构建不稳定",
                body: """构建 #${env.BUILD_NUMBER} 在分支 ${env.BRANCH_NAME} 上状态不稳定，可能存在测试失败。

项目: ${env.JOB_NAME}
分支: ${env.BRANCH_NAME}
构建时间: ${currentBuild.startTimeInMillis ? new Date(currentBuild.startTimeInMillis).format('yyyy-MM-dd HH:mm:ss') : 'N/A'}

查看详情: ${env.BUILD_URL}
查看测试报告: ${env.BUILD_URL}testReport

此邮件由 Langtou CI/CD Pipeline 自动发送。""",
                to: "${EMAIL_RECIPIENTS}",
                mimeType: 'text/html'
            )
        }

        aborted {
            script {
                echo "构建已取消!"
            }
            // Slack通知
            slackSend(
                color: '#808080',
                message: "Langtou 构建已取消! :no_entry:\n项目: ${env.JOB_NAME}\n构建号: #${env.BUILD_NUMBER}\n分支: ${env.BRANCH_NAME}",
                channel: '#langtou-builds',
                tokenCredentialId: 'slack-webhook-token'
            )
        }
    }
}


