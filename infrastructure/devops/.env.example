# ==========================================
# Langtou 开源版 - 环境变量模板
# ==========================================
# 使用说明：
#   1. 复制本文件为 .env
#   2. 将所有 YOUR_VALUE_HERE 替换为你的实际值
#   3. 请勿将真实的 .env 文件提交到代码仓库
# ==========================================

# 基础配置
COMPOSE_PROJECT_NAME=langtou
ENVIRONMENT=dev
TZ=Asia/Shanghai

# 镜像仓库配置（开源版使用公共镜像仓库）
DOCKER_REGISTRY=docker.io
DOCKER_NAMESPACE=library
IMAGE_TAG=latest

# MySQL 配置
MYSQL_ROOT_PASSWORD=YOUR_MYSQL_ROOT_PASSWORD
MYSQL_DATABASE=langtou
MYSQL_USER=langtou
MYSQL_PASSWORD=YOUR_MYSQL_PASSWORD
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=
REDIS_PORT=6379

# Kafka 配置
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=langtou-zookeeper-dev:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_PORT=9092

# Elasticsearch 配置
ELASTIC_PASSWORD=YOUR_ELASTIC_PASSWORD
ELASTIC_PORT=9200
KIBANA_PORT=5601

# Nacos 配置
NACOS_SERVER_PORT=8848
NACOS_AUTH_ENABLE=false
NACOS_AUTH_TOKEN=
NACOS_AUTH_IDENTITY_KEY=
NACOS_AUTH_IDENTITY_VALUE=

# MinIO 配置
MINIO_ACCESS_KEY=YOUR_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=YOUR_MINIO_SECRET_KEY

# 微服务端口配置
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CONTENT_SERVICE_PORT=8082
INTERACT_SERVICE_PORT=8083
MESSAGE_SERVICE_PORT=8084

# Python 推荐服务端口
RECOMMENDATION_PORT=8000

# JVM 配置
JVM_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=YOUR_GRAFANA_PASSWORD

# 日志配置
LOG_LEVEL=INFO
LOG_MAX_SIZE=100m
LOG_MAX_FILE=10

# JWT 密钥（请使用随机生成的强密钥）
JWT_SECRET=YOUR_RANDOM_JWT_SECRET_KEY
