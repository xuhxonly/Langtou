# ==========================================
# Langtou DevOps 环境变量配置
# ==========================================
# 使用说明：
#   1. 复制本文件为 .env 后，将所有 CHANGE_ME 替换为实际值
#   2. 生产环境严禁使用默认值
# ==========================================

# 基础配置
COMPOSE_PROJECT_NAME=langtou
ENVIRONMENT=dev
TZ=Asia/Shanghai

# 镜像仓库配置
DOCKER_REGISTRY=registry.langtou.local
DOCKER_NAMESPACE=langtou
IMAGE_TAG=latest

# MySQL 配置
MYSQL_ROOT_PASSWORD=CHANGE_ME
MYSQL_DATABASE=langtou
MYSQL_USER=langtou
MYSQL_PASSWORD=CHANGE_ME
MYSQL_PORT=3306

# Redis 配置
REDIS_PASSWORD=CHANGE_ME
REDIS_PORT=6379

# Kafka 配置
KAFKA_BROKER_ID=1
KAFKA_ZOOKEEPER_CONNECT=langtou-zookeeper-dev:2181
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:9092
KAFKA_PORT=9092

# Elasticsearch 配置
ELASTIC_PASSWORD=CHANGE_ME
ELASTIC_PORT=9200
KIBANA_PORT=5601

# Nacos 配置
NACOS_SERVER_PORT=8848
NACOS_AUTH_ENABLE=true
NACOS_AUTH_TOKEN=CHANGE_ME
NACOS_AUTH_IDENTITY_KEY=langtou
NACOS_AUTH_IDENTITY_VALUE=CHANGE_ME

# 微服务端口配置
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
CONTENT_SERVICE_PORT=8082
INTERACT_SERVICE_PORT=8083
MESSAGE_SERVICE_PORT=8084

# Python 推荐服务端口
RECOMMENDATION_PORT=8000

# JVM 配置
JVM_OPTS=-Xms512m -Xmx1024m -XX:+UseG1GC

# 监控配置
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# 日志配置
LOG_LEVEL=INFO
LOG_MAX_SIZE=100m
LOG_MAX_FILE=10

# JWT 密钥（生产环境请使用随机生成的强密钥）
JWT_SECRET=langtou-dev-jwt-secret-key-please-change-in-production-2024
